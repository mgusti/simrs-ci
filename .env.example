# ============================================================
# Docker External Port Configuration
# ============================================================
# Salin file ini sebagai .env dan sesuaikan nilainya.
# File .env TIDAK boleh di-commit ke git.

# --- Port Aplikasi (Apache) ---
APP_PORT=8082

# --- Port Database (MariaDB) ---
DB_PORT=3308

# --- Konfigurasi Database ---
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=ci3db
MYSQL_USER=ci3user
MYSQL_PASSWORD=ci3pass
